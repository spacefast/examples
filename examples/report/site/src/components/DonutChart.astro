---
// Donut chart, server-rendered as inline SVG.
// Used for team-size and primary-role breakdowns.
interface Slice {
  label: string;
  value: number;
  color: string;
}
interface Props {
  slices: Slice[];
  centerLabel?: string;
}
const { slices, centerLabel = '' } = Astro.props as Props;

const total = slices.reduce((s, x) => s + x.value, 0);
const size = 220;
const cx = size / 2;
const cy = size / 2;
const r = 86;
const stroke = 30;
const circ = 2 * Math.PI * r;

// Build dash-offset segments around the ring.
let acc = 0;
const segs = slices.map((s) => {
  const frac = s.value / total;
  const seg = {
    ...s,
    frac,
    pct: Math.round(frac * 100),
    dash: frac * circ,
    offset: -acc * circ,
  };
  acc += frac;
  return seg;
});

const top = segs[0];
---

<div class="donut-wrap">
  <svg
    class="donut"
    viewBox={`0 0 ${size} ${size}`}
    role="img"
    aria-label={`Donut chart. ${segs
      .map((s) => `${s.label}: ${s.pct}%`)
      .join('. ')}.`}
  >
    <circle cx={cx} cy={cy} r={r} fill="none" stroke="var(--line-soft)" stroke-width={stroke} />
    <g transform={`rotate(-90 ${cx} ${cy})`}>
      {
        segs.map((s, i) => (
          <circle
            cx={cx}
            cy={cy}
            r={r}
            fill="none"
            stroke={s.color}
            stroke-width={stroke}
            stroke-dasharray={`${s.dash} ${circ - s.dash}`}
            stroke-dashoffset={s.offset}
            class="seg"
            style={`--d:${i * 90}ms`}
          />
        ))
      }
    </g>
    <text x={cx} y={cy - 6} text-anchor="middle" class="donut-big num">{top.pct}%</text>
    <text x={cx} y={cy + 14} text-anchor="middle" class="donut-cap">{centerLabel}</text>
  </svg>

  <ul class="donut-legend">
    {
      segs.map((s) => (
        <li>
          <span class="swatch" style={`background:${s.color}`} />
          <span class="dl-label">{s.label}</span>
          <span class="num dl-pct">{s.pct}%</span>
        </li>
      ))
    }
  </ul>
</div>

<style>
  .donut-wrap {
    display: flex;
    gap: 14px clamp(16px, 4vw, 34px);
    align-items: center;
    flex-wrap: wrap;
  }
  .donut {
    width: clamp(170px, 42%, 220px);
    height: auto;
    flex: none;
  }
  .seg {
    animation: dash 0.9s ease both;
    animation-delay: var(--d);
  }
  @keyframes dash {
    from {
      opacity: 0;
      stroke-dasharray: 0 1000;
    }
  }
  @media (prefers-reduced-motion: reduce) {
    .seg {
      animation: none;
    }
  }
  .donut-big {
    fill: var(--ink);
    font-size: 30px;
    font-weight: 600;
  }
  .donut-cap {
    fill: var(--ink-3);
    font-size: 11px;
    font-family: var(--font-mono);
    text-transform: uppercase;
    letter-spacing: 0.1em;
  }
  .donut-legend {
    margin: 0;
    padding: 0;
    list-style: none;
    flex: 1;
    min-width: 150px;
    display: grid;
    gap: 9px;
  }
  .donut-legend li {
    display: grid;
    grid-template-columns: 12px 1fr auto;
    align-items: center;
    gap: 10px;
    font-size: 14.5px;
    color: var(--ink-2);
    border-bottom: 1px solid var(--line-soft);
    padding-bottom: 8px;
  }
  .donut-legend li:last-child {
    border-bottom: 0;
    padding-bottom: 0;
  }
  .swatch {
    width: 12px;
    height: 12px;
    border-radius: 3px;
  }
  .dl-pct {
    color: var(--ink);
    font-weight: 600;
  }
</style>
