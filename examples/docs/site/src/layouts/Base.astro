---
import '../styles/global.css';
import TopNav from '../components/TopNav.astro';
import Search from '../components/Search.astro';
import { site } from '../data/site';

interface Props {
  title: string;
  description?: string;
}
const { title, description = site.blurb } = Astro.props;
const fullTitle = title === 'Overview' ? `${site.name} — ${site.tagline}` : `${title} · ${site.name} docs`;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <title>{fullTitle}</title>
    <meta name="description" content={description} />
    <meta name="theme-color" content="#0b0f14" />

    <meta property="og:type" content="website" />
    <meta property="og:title" content={fullTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content="https://picsum.photos/seed/ledger-og/1200/630" />
    <meta name="twitter:card" content="summary_large_image" />

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Space+Grotesk:wght@500;600;700&family=Inter:wght@400;500;600;700&family=JetBrains+Mono:wght@400;500;600&display=swap"
      rel="stylesheet"
    />
  </head>
  <body>
    <a class="skip-link" href="#main">Skip to content</a>

    <div class="verbanner" data-verbanner role="status">
      <span>You're viewing the <b data-verlabel>v2.3</b> docs.</span>
      <button type="button" data-verlatest>Switch to latest →</button>
    </div>

    <TopNav />
    <slot />
    <Search />

    <script src="https://spacefast.com/badge.js" data-example="docs"></script>
  </body>
</html>
