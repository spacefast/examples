---
import Layout from '../layouts/Layout.astro';
import Nav from '../components/Nav.astro';
import Hero from '../components/Hero.astro';
import Story from '../components/Story.astro';
import Details from '../components/Details.astro';
import Travel from '../components/Travel.astro';
import Gallery from '../components/Gallery.astro';
import Registry from '../components/Registry.astro';
import Rsvp from '../components/Rsvp.astro';
import Faq from '../components/Faq.astro';
import Footer from '../components/Footer.astro';
import { wedding } from '../data/wedding';

const title = `${wedding.partnerA} & ${wedding.partnerB} — ${wedding.dateLong}`;
const description = `${wedding.partnerA} and ${wedding.partnerB} are getting married at ${wedding.venue} in ${wedding.city} on ${wedding.dateLong}. RSVP, travel, registry, and all the details.`;
---

<Layout title={title} description={description}>
  <Nav />
  <main>
    <Hero />
    <Story />
    <Details />
    <Travel />
    <Gallery />
    <Registry />
    <Rsvp />
    <Faq />
  </main>
  <Footer />
</Layout>
