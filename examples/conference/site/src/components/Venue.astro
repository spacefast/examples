---
import { conf, venue } from '../data/conf';
---

<section class="section section--line venue" id="venue">
  <div class="wrap">
    <div class="venue__top">
      <div class="venue__intro">
        <p class="eyebrow">Venue & travel</p>
        <h2 class="section-title">{conf.venue}</h2>
        <p class="venue__address">{conf.address}</p>
        <p class="lede venue__lede">{venue.intro}</p>
        <a class="btn btn--ghost" href={conf.mapUrl} target="_blank" rel="noopener noreferrer">
          Open in Maps
          <svg viewBox="0 0 16 16" width="14" height="14" aria-hidden="true">
            <path
              d="M5 3h8v8M13 3L4 12"
              fill="none"
              stroke="currentColor"
              stroke-width="2"
              stroke-linecap="round"
              stroke-linejoin="round"
            />
          </svg>
        </a>
      </div>
      <figure class="venue__photo">
        <img
          src="https://picsum.photos/seed/devhorizon-2026-venue/900/1100"
          alt="The glass façade of the Lisbon Congress Centre at dusk, with the river behind it"
          loading="lazy"
          width="900"
          height="1100"
        />
      </figure>
    </div>

    <div class="venue__cols">
      <div class="venue__col">
        <h3 class="venue__col-title">Getting there</h3>
        <ul class="venue__list">
          {
            venue.getThere.map((g) => (
              <li>
                <strong>{g.head}</strong>
                <span>{g.body}</span>
              </li>
            ))
          }
        </ul>
      </div>
      <div class="venue__col">
        <h3 class="venue__col-title">Where to stay</h3>
        <ul class="venue__hotels">
          {
            venue.hotels.map((h) => (
              <li>
                <span class="venue__hotel-head">
                  <strong>{h.name}</strong>
                  <span class="tag">{h.tag}</span>
                </span>
                <span class="venue__hotel-note">{h.note}</span>
              </li>
            ))
          }
        </ul>
      </div>
    </div>
  </div>
</section>

<style>
  .venue__top {
    display: grid;
    grid-template-columns: 1.25fr 0.85fr;
    gap: clamp(1.5rem, 5vw, 3rem);
    align-items: center;
    margin-bottom: clamp(2.5rem, 6vw, 3.6rem);
  }
  .venue__address {
    font-family: var(--mono);
    font-size: 0.86rem;
    color: var(--ink-faint);
    margin: 0.3rem 0 1.1rem;
  }
  .venue__lede {
    margin-bottom: 1.6rem;
  }
  .venue__photo {
    margin: 0;
    border-radius: var(--radius);
    overflow: hidden;
    border: 1px solid var(--line);
  }
  .venue__photo img {
    width: 100%;
    height: 100%;
    max-height: 420px;
    object-fit: cover;
  }

  .venue__cols {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: clamp(1.5rem, 5vw, 3rem);
  }
  .venue__col-title {
    font-size: 1.3rem;
    margin-bottom: 1.1rem;
  }
  .venue__list {
    list-style: none;
    margin: 0;
    padding: 0;
    display: grid;
    gap: 1.1rem;
  }
  .venue__list li {
    display: grid;
    gap: 0.25rem;
  }
  .venue__list strong {
    color: var(--ink);
    font-size: 0.98rem;
  }
  .venue__list span {
    color: var(--ink-soft);
    font-size: 0.93rem;
  }

  .venue__hotels {
    list-style: none;
    margin: 0;
    padding: 0;
    display: grid;
    gap: 0.9rem;
  }
  .venue__hotels li {
    border: 1px solid var(--line);
    border-radius: var(--radius-sm);
    padding: 1rem 1.1rem;
    background: var(--surface);
  }
  .venue__hotel-head {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 0.8rem;
    margin-bottom: 0.35rem;
  }
  .venue__hotel-head strong {
    color: var(--ink);
    font-size: 1rem;
  }
  .venue__hotel-note {
    color: var(--ink-soft);
    font-size: 0.9rem;
  }

  @media (max-width: 820px) {
    .venue__top {
      grid-template-columns: 1fr;
    }
    .venue__photo {
      order: -1;
    }
    .venue__cols {
      grid-template-columns: 1fr;
    }
  }
</style>
