---
import { speakers } from '../data/conf';
---

<section class="section section--line speakers" id="speakers">
  <div class="wrap">
    <div class="speakers__head">
      <div>
        <p class="eyebrow">The lineup</p>
        <h2 class="section-title">Eight people who shipped it.</h2>
      </div>
      <p class="lede">
        Every talk comes from someone who built the thing they are talking about. Tap a card to read
        the abstract.
      </p>
    </div>

    <ul class="speakers__grid">
      {
        speakers.map((s) => (
          <li class="speaker">
            <details class="speaker__details">
              <summary class="speaker__summary">
                <span class="speaker__media">
                  <img
                    src={`https://picsum.photos/seed/${s.seed}/640/720`}
                    alt={`${s.name}, ${s.role} at ${s.company}`}
                    loading="lazy"
                    width="640"
                    height="720"
                  />
                  {s.keynote && <span class="speaker__keynote tag tag--accent">Keynote</span>}
                </span>
                <span class="speaker__body">
                  <span class="speaker__name">{s.name}</span>
                  <span class="speaker__role">
                    {s.role} · {s.company}
                  </span>
                  <span class="speaker__talk">“{s.talk}”</span>
                  <span class="speaker__more">
                    <span class="speaker__more-closed">Read abstract</span>
                    <span class="speaker__more-open">Hide abstract</span>
                    <svg viewBox="0 0 16 16" width="14" height="14" aria-hidden="true">
                      <path
                        d="M4 6l4 4 4-4"
                        fill="none"
                        stroke="currentColor"
                        stroke-width="2"
                        stroke-linecap="round"
                        stroke-linejoin="round"
                      />
                    </svg>
                  </span>
                </span>
              </summary>
              <p class="speaker__abstract">{s.abstract}</p>
            </details>
          </li>
        ))
      }
    </ul>
  </div>
</section>

<style>
  .speakers__head {
    display: grid;
    grid-template-columns: 1fr minmax(0, 0.9fr);
    gap: clamp(1rem, 5vw, 3rem);
    align-items: end;
    margin-bottom: clamp(2.2rem, 5vw, 3.2rem);
  }
  @media (max-width: 760px) {
    .speakers__head {
      grid-template-columns: 1fr;
      gap: 0.8rem;
    }
  }

  .speakers__grid {
    list-style: none;
    margin: 0;
    padding: 0;
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(248px, 1fr));
    gap: 1.1rem;
  }
  .speaker {
    min-width: 0;
  }
  .speaker__details {
    height: 100%;
    border: 1px solid var(--line);
    border-radius: var(--radius);
    overflow: hidden;
    background: var(--surface);
    transition: border-color 0.2s ease, transform 0.2s ease, box-shadow 0.2s ease;
  }
  .speaker__details:hover {
    border-color: var(--line-strong);
    transform: translateY(-3px);
    box-shadow: var(--shadow);
  }
  .speaker__details[open] {
    border-color: rgba(139, 123, 255, 0.5);
  }
  .speaker__summary {
    cursor: pointer;
    list-style: none;
    display: block;
  }
  .speaker__summary::-webkit-details-marker {
    display: none;
  }
  .speaker__media {
    position: relative;
    display: block;
    aspect-ratio: 4 / 4.2;
    overflow: hidden;
    background: var(--surface-2);
  }
  .speaker__media img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    filter: grayscale(0.35) contrast(1.02);
    transition: filter 0.3s ease, transform 0.4s ease;
  }
  .speaker__details:hover .speaker__media img,
  .speaker__details[open] .speaker__media img {
    filter: grayscale(0) contrast(1.02);
    transform: scale(1.03);
  }
  .speaker__keynote {
    position: absolute;
    top: 0.7rem;
    left: 0.7rem;
    background: rgba(7, 7, 13, 0.7);
    backdrop-filter: blur(4px);
  }
  .speaker__body {
    display: block;
    padding: 1rem 1.1rem 1.15rem;
  }
  .speaker__name {
    display: block;
    font-family: var(--display);
    font-weight: 600;
    font-size: 1.18rem;
    color: var(--ink);
  }
  .speaker__role {
    display: block;
    font-size: 0.82rem;
    color: var(--ink-faint);
    margin-top: 0.15rem;
  }
  .speaker__talk {
    display: block;
    margin-top: 0.75rem;
    color: var(--teal);
    font-weight: 500;
    font-size: 0.98rem;
    line-height: 1.35;
  }
  .speaker__more {
    display: inline-flex;
    align-items: center;
    gap: 0.35rem;
    margin-top: 0.85rem;
    font-family: var(--mono);
    font-size: 0.72rem;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--ink-soft);
  }
  .speaker__more svg {
    transition: transform 0.2s ease;
  }
  .speaker__details[open] .speaker__more svg {
    transform: rotate(180deg);
  }
  .speaker__more-open {
    display: none;
  }
  .speaker__details[open] .speaker__more-closed {
    display: none;
  }
  .speaker__details[open] .speaker__more-open {
    display: inline;
  }
  .speaker__abstract {
    margin: 0;
    padding: 0 1.1rem 1.2rem;
    color: var(--ink-soft);
    font-size: 0.93rem;
    line-height: 1.6;
  }
</style>
