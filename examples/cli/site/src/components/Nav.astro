---
import { project } from '../data/site';
---

<header class="nav">
  <div class="wrap nav__inner">
    <a class="nav__brand" href="#top" aria-label={`${project.name} home`}>
      <svg class="nav__mark" viewBox="0 0 32 32" aria-hidden="true">
        <path
          d="M9 10.5h7.5c4 0 6.5 2.4 6.5 5.5s-2.5 5.5-6.5 5.5H9z"
          fill="none"
          stroke="currentColor"
          stroke-width="2.6"
          stroke-linejoin="round"></path>
        <circle cx="22.5" cy="9.5" r="2.2" fill="var(--violet)"></circle>
      </svg>
      <span>{project.name}</span>
      <span class="nav__ver">{project.version}</span>
    </a>

    <nav class="nav__links" aria-label="Primary">
      <a href="#features">Features</a>
      <a href="#how">How it works</a>
      <a href="#benchmark">Benchmarks</a>
      <a href="#community">Community</a>
      <a href={project.docs}>Docs</a>
    </nav>

    <div class="nav__right">
      <a class="nav__stars" href={project.repo} aria-label={`Star ${project.name} on GitHub`}>
        <svg viewBox="0 0 16 16" width="15" height="15" aria-hidden="true">
          <path
            fill="currentColor"
            d="M8 .25a8 8 0 0 0-2.53 15.59c.4.07.55-.17.55-.38v-1.34c-2.23.49-2.7-1.07-2.7-1.07-.36-.93-.89-1.18-.89-1.18-.73-.5.05-.49.05-.49.81.06 1.23.83 1.23.83.72 1.23 1.88.87 2.34.67.07-.52.28-.87.5-1.07-1.78-.2-3.64-.89-3.64-3.95 0-.87.31-1.59.83-2.15-.08-.2-.36-1.02.08-2.12 0 0 .67-.21 2.2.82a7.6 7.6 0 0 1 4 0c1.53-1.03 2.2-.82 2.2-.82.44 1.1.16 1.92.08 2.12.52.56.83 1.28.83 2.15 0 3.07-1.87 3.75-3.65 3.95.29.25.54.73.54 1.48v2.2c0 .21.15.46.55.38A8 8 0 0 0 8 .25Z"
          ></path>
        </svg>
        <span>{project.stars}</span>
      </a>
      <a class="btn nav__cta" href="#quickstart">Get started</a>
    </div>
  </div>
</header>

<style>
  .nav {
    position: sticky;
    top: 0;
    z-index: 50;
    backdrop-filter: blur(12px);
    background: color-mix(in srgb, var(--bg) 78%, transparent);
    border-bottom: 1px solid var(--line);
  }
  .nav__inner {
    display: flex;
    align-items: center;
    gap: 1.5rem;
    height: 64px;
  }
  .nav__brand {
    display: inline-flex;
    align-items: center;
    gap: 0.55rem;
    font-family: var(--display);
    font-weight: 700;
    font-size: 1.12rem;
    color: var(--accent);
  }
  .nav__brand span:nth-of-type(1) {
    color: var(--ink);
  }
  .nav__mark {
    width: 26px;
    height: 26px;
  }
  .nav__ver {
    font-family: var(--mono);
    font-size: 0.64rem;
    font-weight: 500;
    letter-spacing: 0.04em;
    color: var(--ink-faint);
    border: 1px solid var(--line);
    border-radius: 999px;
    padding: 0.12rem 0.45rem;
    margin-left: 0.1rem;
  }
  .nav__links {
    display: none;
    gap: 1.5rem;
    margin-inline: auto;
    font-size: 0.92rem;
    color: var(--ink-soft);
  }
  .nav__links a:hover {
    color: var(--ink);
  }
  .nav__right {
    display: flex;
    align-items: center;
    gap: 0.7rem;
    margin-left: auto;
  }
  .nav__stars {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    font-family: var(--mono);
    font-size: 0.82rem;
    color: var(--ink-soft);
    border: 1px solid var(--line-strong);
    border-radius: 999px;
    padding: 0.42rem 0.8rem;
    transition: border-color 0.16s ease, color 0.16s ease;
  }
  .nav__stars:hover {
    color: var(--ink);
    border-color: var(--accent);
  }
  .nav__cta {
    padding: 0.5rem 1rem;
    font-size: 0.9rem;
  }
  @media (max-width: 720px) {
    .nav__cta {
      display: none;
    }
  }
  @media (min-width: 900px) {
    .nav__links {
      display: flex;
    }
    .nav__right {
      margin-left: 0;
    }
  }
</style>
