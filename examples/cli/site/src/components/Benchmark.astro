---
import { benchmark, testimonial } from '../data/site';
---

<section class="section bench" id="benchmark">
  <div class="wrap bench__inner">
    <div class="bench__chart">
      <div class="section-head">
        <p class="eyebrow">Benchmarks</p>
        <h2>{benchmark.heading}</h2>
        <p>{benchmark.sub}</p>
      </div>

      <div class="bars" role="img" aria-label={benchmark.sub}>
        {
          benchmark.rows.map((r) => (
            <div class={`bar ${r.us ? 'bar--us' : ''}`}>
              <div class="bar__head">
                <span class="bar__label">{r.label}</span>
                <span class="bar__value">
                  {r.display}
                  {r.caveat ? <em class="bar__caveat"> · {r.caveat}</em> : null}
                </span>
              </div>
              <div class="bar__track">
                <span class="bar__fill" style={`width:${r.value}%`} />
              </div>
            </div>
          ))
        }
      </div>
      <p class="bench__note">{benchmark.note}</p>
    </div>

    <figure class="quote">
      <svg class="quote__mark" viewBox="0 0 32 32" aria-hidden="true">
        <path
          fill="currentColor"
          d="M13 8c-4.4 1.6-7 5.2-7 9.6 0 3.6 2.2 6 5.2 6 2.6 0 4.6-1.9 4.6-4.5 0-2.4-1.7-4.2-4-4.4.3-2.2 2-4 4.4-4.9L13 8Zm12 0c-4.4 1.6-7 5.2-7 9.6 0 3.6 2.2 6 5.2 6 2.6 0 4.6-1.9 4.6-4.5 0-2.4-1.7-4.2-4-4.4.3-2.2 2-4 4.4-4.9L25 8Z"
        ></path>
      </svg>
      <blockquote class="quote__text">{testimonial.quote}</blockquote>
      <figcaption class="quote__by">
        <img
          class="quote__avatar"
          src="https://picsum.photos/seed/drift-cli-priya/96/96"
          alt=""
          width="48"
          height="48"
          loading="lazy"
        />
        <span>
          <strong>{testimonial.author}</strong>
          <small>{testimonial.role}</small>
        </span>
      </figcaption>
    </figure>
  </div>
</section>

<style>
  .bench {
    border-top: 1px solid var(--line);
    background: var(--bg-soft);
  }
  .bench__inner {
    display: grid;
    gap: 2.4rem;
    align-items: start;
  }
  .bars {
    display: grid;
    gap: 1.3rem;
  }
  .bar__head {
    display: flex;
    justify-content: space-between;
    align-items: baseline;
    gap: 1rem;
    margin-bottom: 0.5rem;
  }
  .bar__label {
    font-weight: 500;
    color: var(--ink-soft);
    font-size: 0.94rem;
  }
  .bar--us .bar__label {
    color: var(--ink);
    font-weight: 700;
  }
  .bar__value {
    font-family: var(--mono);
    font-size: 0.84rem;
    color: var(--ink-soft);
  }
  .bar--us .bar__value {
    color: var(--accent);
    font-weight: 600;
  }
  .bar__caveat {
    color: var(--ink-faint);
    font-style: normal;
    font-size: 0.78rem;
  }
  .bar__track {
    height: 12px;
    border-radius: 999px;
    background: rgba(255, 255, 255, 0.05);
    overflow: hidden;
  }
  .bar__fill {
    display: block;
    height: 100%;
    border-radius: 999px;
    background: rgba(255, 255, 255, 0.16);
  }
  .bar--us .bar__fill {
    background: linear-gradient(90deg, var(--accent), var(--accent-deep));
    box-shadow: 0 0 24px -4px rgba(52, 225, 196, 0.6);
  }
  .bench__note {
    margin-top: 1.6rem;
    color: var(--ink-faint);
    font-size: 0.88rem;
    max-width: 58ch;
  }

  .quote {
    margin: 0;
    border: 1px solid var(--line);
    border-radius: var(--radius-lg);
    background: linear-gradient(160deg, var(--panel-2), var(--panel));
    padding: 2rem;
    position: relative;
  }
  .quote__mark {
    width: 36px;
    height: 36px;
    color: var(--accent);
    opacity: 0.55;
  }
  .quote__text {
    margin: 1rem 0 1.6rem;
    font-family: var(--display);
    font-weight: 500;
    font-size: clamp(1.15rem, 2.6vw, 1.4rem);
    line-height: 1.4;
    color: var(--ink);
  }
  .quote__by {
    display: flex;
    align-items: center;
    gap: 0.85rem;
  }
  .quote__avatar {
    width: 48px;
    height: 48px;
    border-radius: 50%;
    object-fit: cover;
    border: 1px solid var(--line-strong);
  }
  .quote__by span {
    display: flex;
    flex-direction: column;
    line-height: 1.3;
  }
  .quote__by strong {
    font-weight: 600;
  }
  .quote__by small {
    color: var(--ink-faint);
    font-size: 0.84rem;
  }
  @media (min-width: 940px) {
    .bench__inner {
      grid-template-columns: 1.35fr 1fr;
      gap: 3.2rem;
    }
    .quote {
      position: sticky;
      top: 90px;
    }
  }
</style>
