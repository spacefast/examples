---
import { project, docCards } from '../data/site';
---

<section class="section community" id="community">
  <div class="wrap">
    <div class="section-head">
      <p class="eyebrow">Community</p>
      <h2>Built in the open</h2>
      <p>
        Drift is {project.license}-licensed and developed entirely on GitHub. File an
        issue, open a PR, or hang out in Discord — first-time contributors very welcome.
      </p>
    </div>

    <div class="community__cards">
      <a class="ccard ccard--github" href={project.repo}>
        <span class="ccard__icon" aria-hidden="true">
          <svg viewBox="0 0 16 16" width="24" height="24">
            <path fill="currentColor" d="M8 .25a8 8 0 0 0-2.53 15.59c.4.07.55-.17.55-.38v-1.34c-2.23.49-2.7-1.07-2.7-1.07-.36-.93-.89-1.18-.89-1.18-.73-.5.05-.49.05-.49.81.06 1.23.83 1.23.83.72 1.23 1.88.87 2.34.67.07-.52.28-.87.5-1.07-1.78-.2-3.64-.89-3.64-3.95 0-.87.31-1.59.83-2.15-.08-.2-.36-1.02.08-2.12 0 0 .67-.21 2.2.82a7.6 7.6 0 0 1 4 0c1.53-1.03 2.2-.82 2.2-.82.44 1.1.16 1.92.08 2.12.52.56.83 1.28.83 2.15 0 3.07-1.87 3.75-3.65 3.95.29.25.54.73.54 1.48v2.2c0 .21.15.46.55.38A8 8 0 0 0 8 .25Z"></path>
          </svg>
        </span>
        <h3>Star us on GitHub</h3>
        <p>{project.starsExact} stars and counting. Issues triaged within a day.</p>
        <span class="ccard__cta">github.com/driftlabs/drift →</span>
      </a>

      <a class="ccard ccard--discord" href={project.discord}>
        <span class="ccard__icon" aria-hidden="true">
          <svg viewBox="0 0 24 24" width="26" height="26">
            <path fill="currentColor" d="M20 4.4A18 18 0 0 0 15.5 3l-.3.5a16 16 0 0 1 4 1.3 14 14 0 0 0-12.4 0 16 16 0 0 1 4-1.3L10.5 3A18 18 0 0 0 6 4.4C3.3 8.3 2.6 12.1 3 15.8A18 18 0 0 0 8.4 18l.6-1a11 11 0 0 1-1.8-.9l.4-.3a13 13 0 0 0 11 0l.4.3a11 11 0 0 1-1.8.9l.6 1a18 18 0 0 0 5.4-2.2c.4-4.2-.6-8-3.2-11.4ZM9.3 13.6c-.9 0-1.6-.8-1.6-1.8s.7-1.8 1.6-1.8 1.7.8 1.6 1.8c0 1-.7 1.8-1.6 1.8Zm5.4 0c-.9 0-1.6-.8-1.6-1.8s.7-1.8 1.6-1.8 1.7.8 1.6 1.8c0 1-.7 1.8-1.6 1.8Z"></path>
          </svg>
        </span>
        <h3>Join the Discord</h3>
        <p>2,300 developers swapping schema war stories and getting help fast.</p>
        <span class="ccard__cta">discord.gg/drift →</span>
      </a>

      <a class="ccard ccard--contrib" href={`${project.repo}/blob/main/CONTRIBUTING.md`}>
        <span class="ccard__icon" aria-hidden="true">
          <svg viewBox="0 0 24 24" width="24" height="24">
            <path d="M4 17v2a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2v-2M16 7l-4-4-4 4m4-4v12" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"></path>
          </svg>
        </span>
        <h3>Contribute</h3>
        <p>47 good-first-issues open. The dialect adapters are a great place to start.</p>
        <span class="ccard__cta">Read CONTRIBUTING.md →</span>
      </a>
    </div>

    <div class="docs" id="docs">
      <h3 class="docs__head">From the docs</h3>
      <div class="docs__grid">
        {
          docCards.map((d) => (
            <a class="doc" href={d.href}>
              <span class="doc__kicker">{d.kicker}</span>
              <strong class="doc__title">{d.title}</strong>
              <span class="doc__body">{d.body}</span>
            </a>
          ))
        }
      </div>
    </div>
  </div>
</section>

<style>
  .community {
    border-top: 1px solid var(--line);
  }
  .community__cards {
    display: grid;
    gap: 1rem;
    grid-template-columns: 1fr;
  }
  .ccard {
    border: 1px solid var(--line);
    border-radius: var(--radius);
    background: var(--panel);
    padding: 1.7rem;
    transition: border-color 0.18s ease, transform 0.18s ease;
  }
  .ccard:hover {
    transform: translateY(-3px);
  }
  .ccard--github:hover {
    border-color: var(--ink-soft);
  }
  .ccard--discord:hover {
    border-color: var(--violet);
  }
  .ccard--contrib:hover {
    border-color: var(--accent);
  }
  .ccard__icon {
    display: inline-flex;
    color: var(--ink);
  }
  .ccard--discord .ccard__icon {
    color: var(--violet);
  }
  .ccard--contrib .ccard__icon {
    color: var(--accent);
  }
  .ccard h3 {
    font-size: 1.18rem;
    font-weight: 600;
    margin: 1rem 0 0.45rem;
  }
  .ccard p {
    color: var(--ink-soft);
    font-size: 0.94rem;
    margin-bottom: 1.1rem;
  }
  .ccard__cta {
    font-family: var(--mono);
    font-size: 0.8rem;
    color: var(--accent);
  }

  .docs {
    margin-top: 3.4rem;
  }
  .docs__head {
    font-size: 1.3rem;
    font-weight: 600;
    margin-bottom: 1.2rem;
  }
  .docs__grid {
    display: grid;
    gap: 0.8rem;
    grid-template-columns: 1fr;
  }
  .doc {
    display: flex;
    flex-direction: column;
    gap: 0.35rem;
    padding: 1.2rem 1.3rem;
    border: 1px solid var(--line);
    border-radius: var(--radius);
    background: var(--bg-soft);
    transition: border-color 0.16s ease, background 0.16s ease;
  }
  .doc:hover {
    border-color: var(--accent);
    background: var(--panel);
  }
  .doc__kicker {
    font-family: var(--mono);
    font-size: 0.68rem;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--accent);
  }
  .doc__title {
    font-family: var(--display);
    font-size: 1.05rem;
    font-weight: 600;
  }
  .doc__body {
    color: var(--ink-soft);
    font-size: 0.9rem;
  }
  @media (min-width: 760px) {
    .community__cards {
      grid-template-columns: repeat(3, 1fr);
    }
    .docs__grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }
</style>
