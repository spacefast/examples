---
import { sponsors } from '../data/conf';
---

<section class="section section--line sponsors" id="sponsors">
  <div class="wrap">
    <div class="sponsors__head center">
      <p class="eyebrow">Sponsors</p>
      <h2 class="section-title">Made possible by good tools.</h2>
      <p class="lede sponsors__lede">
        The companies below keep the tickets affordable and the espresso flowing. We only take
        sponsors our attendees actually use.
      </p>
    </div>

    {
      sponsors.map((group) => (
        <div class="sponsors__tier">
          <div class="sponsors__tier-label">
            <span class="sponsors__tier-name">{group.tier}</span>
            <span class="sponsors__tier-blurb">{group.blurb}</span>
          </div>
          <ul class={`sponsors__grid sponsors__grid--${group.tier.toLowerCase()}`}>
            {group.sponsors.map((s) => (
              <li class="sponsor">
                <span class="sponsor__name">{s.name}</span>
                <span class="sponsor__kind">{s.kind}</span>
              </li>
            ))}
          </ul>
        </div>
      ))
    }

    <div class="sponsors__cta center">
      <p>Put your tool in front of {' '}480 engineers who ship to the browser.</p>
      <a class="btn" href="#footer">Become a sponsor</a>
    </div>
  </div>
</section>

<style>
  .sponsors__head {
    margin-bottom: clamp(2.4rem, 6vw, 3.4rem);
  }
  .center .lede {
    margin-inline: auto;
  }
  .sponsors__tier {
    margin-bottom: 2.4rem;
  }
  .sponsors__tier-label {
    display: flex;
    align-items: baseline;
    gap: 0.8rem;
    flex-wrap: wrap;
    padding-bottom: 0.9rem;
    margin-bottom: 1.1rem;
    border-bottom: 1px solid var(--line);
  }
  .sponsors__tier-name {
    font-family: var(--mono);
    font-size: 0.8rem;
    font-weight: 600;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: var(--teal);
  }
  .sponsors__tier-blurb {
    font-size: 0.9rem;
    color: var(--ink-faint);
  }

  .sponsors__grid {
    list-style: none;
    margin: 0;
    padding: 0;
    display: grid;
    gap: 0.9rem;
  }
  .sponsors__grid--platinum {
    grid-template-columns: repeat(auto-fit, minmax(260px, 1fr));
  }
  .sponsors__grid--gold {
    grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
  }
  .sponsors__grid--community {
    grid-template-columns: repeat(auto-fit, minmax(170px, 1fr));
  }

  .sponsor {
    display: flex;
    flex-direction: column;
    gap: 0.25rem;
    border: 1px solid var(--line);
    border-radius: var(--radius-sm);
    background: var(--surface);
    padding: 1.2rem 1.3rem;
    transition: border-color 0.2s ease, transform 0.2s ease;
  }
  .sponsor:hover {
    border-color: var(--line-strong);
    transform: translateY(-2px);
  }
  .sponsor__name {
    font-family: var(--display);
    font-weight: 600;
    font-size: 1.2rem;
    color: var(--ink);
  }
  .sponsors__grid--platinum .sponsor {
    padding: 1.6rem 1.6rem;
    background: var(--grad-soft);
    border-color: var(--line-strong);
  }
  .sponsors__grid--platinum .sponsor__name {
    font-size: 1.5rem;
  }
  .sponsors__grid--community .sponsor__name {
    font-size: 1.05rem;
  }
  .sponsor__kind {
    font-size: 0.82rem;
    color: var(--ink-faint);
  }

  .sponsors__cta {
    margin-top: 2.6rem;
    padding-top: 2.2rem;
    border-top: 1px solid var(--line);
  }
  .sponsors__cta p {
    color: var(--ink-soft);
    margin-bottom: 1.1rem;
  }
</style>
