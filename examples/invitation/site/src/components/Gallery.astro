---
import { gallery, wedding } from '../data/wedding';
---

<section class="section section--tint" id="gallery">
  <div class="wrap center">
    <p class="eyebrow">Us, lately</p>
    <h2 class="section-title">A few favorites</h2>
    <p class="lede">
      Tag your photos from the day with {wedding.hashtag} so none of them get lost.
    </p>
  </div>

  <div class="wrap gallery">
    {
      gallery.map((g, i) => (
        <figure class={`gallery__item gallery__item--${i}`}>
          <img
            src={`https://picsum.photos/seed/${g.seed}/900/900`}
            alt={g.alt}
            loading="lazy"
            width="900"
            height="900"
          />
        </figure>
      ))
    }
  </div>
</section>

<style>
  .gallery {
    margin-top: 2.6rem;
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 0.9rem;
  }
  .gallery__item {
    margin: 0;
    overflow: hidden;
    border-radius: var(--radius);
    box-shadow: 0 14px 34px -28px rgba(44, 42, 36, 0.7);
  }
  .gallery__item img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    aspect-ratio: 1 / 1;
    transition: transform 0.5s ease;
  }
  .gallery__item:hover img {
    transform: scale(1.05);
  }

  @media (min-width: 760px) {
    .gallery {
      grid-template-columns: repeat(4, 1fr);
      grid-auto-rows: 1fr;
    }
    /* Make the first and fourth photos feature-sized for an editorial mosaic */
    .gallery__item--0 {
      grid-column: span 2;
      grid-row: span 2;
    }
    .gallery__item--0 img {
      aspect-ratio: auto;
    }
    .gallery__item--3 {
      grid-column: span 2;
    }
    .gallery__item--3 img {
      aspect-ratio: 2 / 1;
    }
  }
</style>
