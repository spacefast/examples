---
import { site, versions } from '../data/site';
---

<header class="topnav">
  <div class="topnav__inner">
    <button class="sidebar-toggle" data-sidebar-toggle aria-label="Open navigation" aria-expanded="false">
      <svg width="16" height="16" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.7">
        <path d="M2 4h12M2 8h12M2 12h12" stroke-linecap="round" />
      </svg>
      Menu
    </button>

    <a class="brand" href="/" aria-label={`${site.name} home`}>
      <svg width="26" height="26" viewBox="0 0 32 32" aria-hidden="true">
        <defs>
          <linearGradient id="bm" x1="0" y1="0" x2="32" y2="32" gradientUnits="userSpaceOnUse">
            <stop offset="0" stop-color="#34d399" />
            <stop offset="1" stop-color="#38bdf8" />
          </linearGradient>
        </defs>
        <rect width="32" height="32" rx="7" fill="#121823" />
        <path d="M9 9.5h14M9 16h14M9 22.5h9" fill="none" stroke="url(#bm)" stroke-width="2.6" stroke-linecap="round" />
      </svg>
      {site.name}
      <span class="brand__badge">docs</span>
    </a>

    <div class="topnav__spacer"></div>

    <button class="search-trigger" data-search-open type="button" aria-label="Search docs">
      <svg width="15" height="15" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.6">
        <circle cx="7" cy="7" r="4.5" />
        <path d="M11 11l3 3" stroke-linecap="round" />
      </svg>
      <span>Search docs…</span>
      <kbd>⌘K</kbd>
    </button>

    <button class="search-trigger search-trigger--mobile" data-search-open type="button" aria-label="Search docs">
      <svg width="15" height="15" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.6">
        <circle cx="7" cy="7" r="4.5" />
        <path d="M11 11l3 3" stroke-linecap="round" />
      </svg>
    </button>

    <div class="verswitch" data-verswitch>
      <button class="verswitch__btn" type="button" data-vertrigger aria-haspopup="true" aria-expanded="false">
        {site.currentVersion}
        <svg width="11" height="11" viewBox="0 0 12 12" fill="none" stroke="currentColor" stroke-width="1.6">
          <path d="M2.5 4.5L6 8l3.5-3.5" stroke-linecap="round" stroke-linejoin="round" />
        </svg>
      </button>
      <div class="verswitch__menu" role="menu">
        {
          versions.map((v) => (
            <button
              class="verswitch__item"
              role="menuitem"
              type="button"
              data-version={v.label}
              data-active={v.current ? '' : undefined}
            >
              {v.label}
              <span>{v.note}</span>
            </button>
          ))
        }
      </div>
    </div>

    <nav class="topnav__links" aria-label="Resources">
      <a href={site.npm}>npm</a>
      <a class="icon-link" href={site.repo} aria-label="GitHub repository">
        <svg width="19" height="19" viewBox="0 0 16 16" fill="currentColor" aria-hidden="true">
          <path
            d="M8 0C3.58 0 0 3.58 0 8c0 3.54 2.29 6.53 5.47 7.59.4.07.55-.17.55-.38 0-.19-.01-.82-.01-1.49-2.01.37-2.53-.49-2.69-.94-.09-.23-.48-.94-.82-1.13-.28-.15-.68-.52-.01-.53.63-.01 1.08.58 1.23.82.72 1.21 1.87.87 2.33.66.07-.52.28-.87.51-1.07-1.78-.2-3.64-.89-3.64-3.95 0-.87.31-1.59.82-2.15-.08-.2-.36-1.02.08-2.12 0 0 .67-.21 2.2.82.64-.18 1.32-.27 2-.27.68 0 1.36.09 2 .27 1.53-1.04 2.2-.82 2.2-.82.44 1.1.16 1.92.08 2.12.51.56.82 1.27.82 2.15 0 3.07-1.87 3.75-3.65 3.95.29.25.54.73.54 1.48 0 1.07-.01 1.93-.01 2.2 0 .21.15.46.55.38A8.01 8.01 0 0016 8c0-4.42-3.58-8-8-8z"
          />
        </svg>
      </a>
    </nav>
  </div>
</header>

<script>
  // Version dropdown
  const sw = document.querySelector('[data-verswitch]');
  const trigger = sw?.querySelector('[data-vertrigger]') as HTMLButtonElement | null;
  const banner = document.querySelector('[data-verbanner]');
  const bannerLabel = document.querySelector('[data-verlabel]');
  const latestBtn = document.querySelector('[data-verlatest]') as HTMLButtonElement | null;

  const closeVer = () => {
    sw?.removeAttribute('data-open');
    trigger?.setAttribute('aria-expanded', 'false');
  };
  trigger?.addEventListener('click', (e) => {
    e.stopPropagation();
    const open = sw?.hasAttribute('data-open');
    if (open) closeVer();
    else {
      sw?.setAttribute('data-open', '');
      trigger?.setAttribute('aria-expanded', 'true');
    }
  });
  document.addEventListener('click', closeVer);
  document.addEventListener('keydown', (e) => {
    if (e.key === 'Escape') closeVer();
  });

  sw?.querySelectorAll('[data-version]').forEach((item) => {
    item.addEventListener('click', (e) => {
      e.stopPropagation();
      const v = (item as HTMLElement).dataset.version || '';
      sw?.querySelectorAll('[data-version]').forEach((i) => i.removeAttribute('data-active'));
      item.setAttribute('data-active', '');
      if (trigger) trigger.childNodes[0].nodeValue = v + ' ';
      closeVer();
      const isLatest = v === 'v2.4';
      if (isLatest) {
        banner?.removeAttribute('data-show');
      } else {
        if (bannerLabel) bannerLabel.textContent = v;
        banner?.setAttribute('data-show', '');
      }
    });
  });

  latestBtn?.addEventListener('click', () => {
    banner?.removeAttribute('data-show');
    sw?.querySelectorAll('[data-version]').forEach((i) => i.removeAttribute('data-active'));
    const latest = sw?.querySelector('[data-version="v2.4"]');
    latest?.setAttribute('data-active', '');
    if (trigger) trigger.childNodes[0].nodeValue = 'v2.4 ';
  });

  // Mobile sidebar toggle (sidebar lives in Docs layout)
  const sbToggle = document.querySelector('[data-sidebar-toggle]');
  sbToggle?.addEventListener('click', () => {
    const sb = document.querySelector('[data-sidebar]');
    const scrim = document.querySelector('[data-sidebar-scrim]');
    const open = sb?.hasAttribute('data-open');
    if (open) {
      sb?.removeAttribute('data-open');
      scrim?.removeAttribute('data-show');
      sbToggle.setAttribute('aria-expanded', 'false');
    } else {
      sb?.setAttribute('data-open', '');
      scrim?.setAttribute('data-show', '');
      sbToggle.setAttribute('aria-expanded', 'true');
    }
  });
</script>
