---
import { about, studio } from '../data/portfolio';
---

<section class="section about-band" id="about">
  <div class="wrap about-grid">
    <img
      class="reveal"
      src={`https://picsum.photos/seed/${about.headshot.seed}/800/1000?grayscale`}
      alt={about.headshot.alt}
      loading="lazy"
      width="800"
      height="1000"
    />
    <div class="about-body reveal">
      <p class="eyebrow">About</p>
      <p>{about.bio[0]}</p>
      <p>{about.bio[1]}</p>
      <p>
        <a
          href="/about"
          style="color:var(--ink);border-bottom:1px solid var(--ink-faint);text-decoration:none;"
          >Read the full story, press &amp; client list →</a
        >
      </p>
      <div class="clients">
        <p class="clients__label">Selected clients</p>
        <ul class="clients__list">
          {about.clients.slice(0, 8).map((c) => <li>{c}</li>)}
        </ul>
      </div>
    </div>
  </div>
</section>
