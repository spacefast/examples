---
import { wedding } from '../data/wedding';
---

<section class="section section--tint" id="details">
  <div class="wrap center">
    <p class="eyebrow">The Day</p>
    <h2 class="section-title">The Details</h2>
    <div class="ornament" aria-hidden="true"></div>
  </div>

  <div class="wrap details__grid">
    <article class="card">
      <h3>Ceremony</h3>
      <p class="card__time">{wedding.ceremony.time}</p>
      <p class="card__text">{wedding.ceremony.detail}</p>
    </article>

    <article class="card card--accent">
      <h3>The Venue</h3>
      <p class="card__venue">{wedding.venue}</p>
      <p class="card__text">{wedding.address}</p>
      <a class="btn btn--ghost card__map" href={wedding.mapUrl} target="_blank" rel="noopener">
        Open in Maps
      </a>
    </article>

    <article class="card">
      <h3>Reception</h3>
      <p class="card__time">{wedding.reception.time}</p>
      <p class="card__text">{wedding.reception.detail}</p>
    </article>
  </div>

  <div class="wrap dress">
    <div class="dress__inner">
      <span class="dress__tag">Dress code · {wedding.dressCode}</span>
      <p>{wedding.dressCodeNote}</p>
    </div>
  </div>
</section>

<style>
  .details__grid {
    display: grid;
    gap: 1.5rem;
    margin-top: 2.5rem;
  }
  .card {
    background: var(--cream-card);
    border: 1px solid var(--line);
    border-radius: var(--radius);
    padding: 2.1rem 1.8rem;
    text-align: center;
    box-shadow: 0 12px 30px -26px rgba(44, 42, 36, 0.6);
  }
  .card--accent {
    background: var(--olive);
    border-color: var(--olive);
    color: var(--ivory);
  }
  .card--accent h3,
  .card--accent .card__venue {
    color: var(--ivory);
  }
  .card h3 {
    font-size: 1.65rem;
    margin-bottom: 0.6rem;
  }
  .card__time {
    font-family: var(--serif);
    font-size: 1.55rem;
    color: var(--terracotta-deep);
    margin: 0 0 0.5rem;
  }
  .card__venue {
    font-family: var(--serif);
    font-size: 1.5rem;
    margin: 0 0 0.4rem;
  }
  .card__text {
    margin: 0;
    color: var(--ink-soft);
  }
  .card--accent .card__text {
    color: var(--blush);
  }
  .card__map {
    margin-top: 1.2rem;
    border-color: var(--ivory);
    color: var(--ivory);
  }
  .card__map:hover {
    background: var(--ivory);
    color: var(--olive);
  }

  .dress {
    margin-top: 1.5rem;
  }
  .dress__inner {
    background: var(--cream-card);
    border: 1px dashed var(--gold);
    border-radius: var(--radius);
    padding: 1.6rem 1.8rem;
    text-align: center;
  }
  .dress__tag {
    display: inline-block;
    font-family: var(--sans);
    font-weight: 700;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    font-size: 0.78rem;
    color: var(--terracotta);
    margin-bottom: 0.6rem;
  }
  .dress__inner p {
    margin: 0;
    color: var(--ink-soft);
    max-width: 62ch;
    margin-inline: auto;
  }

  @media (min-width: 820px) {
    .details__grid {
      grid-template-columns: repeat(3, 1fr);
      align-items: stretch;
    }
    .card {
      display: flex;
      flex-direction: column;
      justify-content: center;
    }
  }
</style>
