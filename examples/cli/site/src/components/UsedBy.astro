---
import { usedBy } from '../data/site';
---

<section class="section usedby">
  <div class="wrap">
    <p class="usedby__kicker">Shipping migrations at</p>
    <ul class="usedby__wall">
      {
        usedBy.map((co) => (
          <li class="logo">
            <span class="logo__glyph" aria-hidden="true">
              {co.name.charAt(0)}
            </span>
            <span class="logo__name">{co.name}</span>
            <span class="logo__tag">{co.tag}</span>
          </li>
        ))
      }
    </ul>
  </div>
</section>

<style>
  .usedby {
    padding-block: clamp(2.6rem, 6vw, 4rem);
    border-top: 1px solid var(--line);
  }
  .usedby__kicker {
    text-align: center;
    font-family: var(--mono);
    font-size: 0.72rem;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--ink-faint);
    margin-bottom: 1.8rem;
  }
  .usedby__wall {
    list-style: none;
    margin: 0;
    padding: 0;
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 0.8rem;
  }
  .logo {
    display: flex;
    align-items: center;
    gap: 0.7rem;
    padding: 0.85rem 1rem;
    border: 1px solid var(--line);
    border-radius: 11px;
    background: var(--panel);
    transition: border-color 0.16s ease, opacity 0.16s ease;
    opacity: 0.82;
  }
  .logo:hover {
    border-color: var(--line-strong);
    opacity: 1;
  }
  .logo__glyph {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 30px;
    height: 30px;
    flex-shrink: 0;
    border-radius: 8px;
    font-family: var(--display);
    font-weight: 700;
    font-size: 0.95rem;
    color: var(--accent);
    background: rgba(52, 225, 196, 0.1);
    border: 1px solid rgba(52, 225, 196, 0.2);
  }
  .logo__name {
    font-family: var(--display);
    font-weight: 600;
    font-size: 0.96rem;
    color: var(--ink);
  }
  .logo__tag {
    margin-left: auto;
    font-family: var(--mono);
    font-size: 0.68rem;
    color: var(--ink-faint);
    display: none;
  }
  @media (min-width: 560px) {
    .usedby__wall {
      grid-template-columns: repeat(4, 1fr);
    }
  }
  @media (min-width: 860px) {
    .usedby__wall {
      grid-template-columns: repeat(4, 1fr);
    }
    .logo__tag {
      display: inline;
    }
  }
</style>
