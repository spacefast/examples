---
import { wedding } from '../data/wedding';
---

<section class="hero" id="top">
  <img
    class="hero__bg"
    src="https://picsum.photos/seed/maya-and-daniel-hero/1800/1200"
    alt="Golden-hour light over the vineyard rows at Bellecourt Estate"
    fetchpriority="high"
    width="1800"
    height="1200"
  />
  <div class="hero__scrim"></div>

  <div class="wrap hero__inner">
    <p class="hero__kicker">Together with their families</p>
    <h1 class="hero__names">
      {wedding.partnerA}
      <span class="hero__amp" aria-hidden="true">&amp;</span>
      {wedding.partnerB}
    </h1>
    <p class="hero__meta">
      {wedding.dateLong} &nbsp;·&nbsp; {wedding.venue} &nbsp;·&nbsp; {wedding.city}
    </p>

    <div class="countdown" role="timer" aria-live="off" data-countdown data-target={wedding.dateISO}>
      <div class="countdown__unit"><span data-d>—</span><small>Days</small></div>
      <div class="countdown__unit"><span data-h>—</span><small>Hours</small></div>
      <div class="countdown__unit"><span data-m>—</span><small>Minutes</small></div>
      <div class="countdown__unit"><span data-s>—</span><small>Seconds</small></div>
    </div>
    <p class="countdown__done" data-done hidden>We're married! Thank you for celebrating with us. 🥂</p>

    <a class="btn hero__btn" href="#rsvp">RSVP by August 19</a>
  </div>

  <a class="hero__scroll" href="#story" aria-label="Scroll to our story">
    <span></span>
  </a>
</section>

<style>
  .hero {
    position: relative;
    min-height: 100svh;
    display: grid;
    place-items: center;
    text-align: center;
    color: var(--ivory);
    overflow: hidden;
  }
  .hero__bg {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    filter: saturate(0.92) contrast(1.02);
  }
  .hero__scrim {
    position: absolute;
    inset: 0;
    background:
      radial-gradient(120% 90% at 50% 30%, rgba(44, 42, 36, 0.15), rgba(44, 42, 36, 0.62)),
      linear-gradient(180deg, rgba(44, 42, 36, 0.45), rgba(44, 42, 36, 0.35) 40%, rgba(44, 42, 36, 0.7));
  }
  .hero__inner {
    position: relative;
    padding-block: 7rem 5rem;
  }
  .hero__kicker {
    font-size: 0.82rem;
    font-weight: 700;
    letter-spacing: 0.32em;
    text-transform: uppercase;
    margin: 0 0 1.2rem;
    color: var(--blush);
  }
  .hero__names {
    color: var(--ivory);
    font-weight: 500;
    font-size: clamp(3.4rem, 14vw, 8rem);
    letter-spacing: 0.01em;
    text-shadow: 0 2px 30px rgba(0, 0, 0, 0.35);
  }
  .hero__amp {
    display: block;
    font-style: italic;
    font-size: 0.55em;
    color: var(--blush);
    margin-block: -0.1em;
  }
  .hero__meta {
    font-family: var(--serif);
    font-size: clamp(1.05rem, 3.2vw, 1.5rem);
    letter-spacing: 0.04em;
    margin: 1.1rem auto 0;
    color: #f4ede0;
  }

  .countdown {
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    gap: clamp(0.9rem, 4vw, 2.4rem);
    margin: 2.6rem auto 0;
  }
  .countdown__unit {
    display: flex;
    flex-direction: column;
    align-items: center;
    min-width: 64px;
  }
  .countdown__unit span {
    font-family: var(--serif);
    font-size: clamp(2.1rem, 7vw, 3.4rem);
    font-weight: 500;
    line-height: 1;
    font-variant-numeric: tabular-nums;
    color: var(--ivory);
  }
  .countdown__unit small {
    margin-top: 0.45rem;
    font-size: 0.7rem;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    color: var(--blush);
  }
  .countdown__done {
    font-family: var(--serif);
    font-size: clamp(1.3rem, 4vw, 1.9rem);
    margin: 2.4rem auto 0;
    color: var(--ivory);
  }

  .hero__btn {
    margin-top: 2.8rem;
    background: var(--ivory);
    color: var(--olive);
    border-color: var(--ivory);
  }
  .hero__btn:hover {
    background: var(--terracotta);
    color: var(--ivory);
    border-color: var(--terracotta);
  }

  .hero__scroll {
    position: absolute;
    bottom: 1.6rem;
    left: 50%;
    transform: translateX(-50%);
    width: 26px;
    height: 42px;
    border: 2px solid rgba(248, 242, 231, 0.7);
    border-radius: 999px;
    display: grid;
    place-items: start center;
    padding-top: 7px;
  }
  .hero__scroll span {
    width: 4px;
    height: 8px;
    border-radius: 4px;
    background: var(--ivory);
    animation: scrolldot 1.8s ease-in-out infinite;
  }
  @keyframes scrolldot {
    0%,
    100% {
      transform: translateY(0);
      opacity: 1;
    }
    60% {
      transform: translateY(10px);
      opacity: 0.2;
    }
  }
</style>

<script>
  const root = document.querySelector('[data-countdown]');
  const done = document.querySelector('[data-done]');
  if (root) {
    const target = new Date(root.getAttribute('data-target') || '').getTime();
    const elD = root.querySelector('[data-d]');
    const elH = root.querySelector('[data-h]');
    const elM = root.querySelector('[data-m]');
    const elS = root.querySelector('[data-s]');
    const pad = (n: number) => String(n).padStart(2, '0');

    const tick = () => {
      const diff = target - Date.now();
      if (diff <= 0) {
        root.setAttribute('hidden', '');
        done?.removeAttribute('hidden');
        return false;
      }
      const s = Math.floor(diff / 1000);
      if (elD) elD.textContent = String(Math.floor(s / 86400));
      if (elH) elH.textContent = pad(Math.floor((s % 86400) / 3600));
      if (elM) elM.textContent = pad(Math.floor((s % 3600) / 60));
      if (elS) elS.textContent = pad(s % 60);
      return true;
    };

    if (tick()) {
      const id = setInterval(() => {
        if (!tick()) clearInterval(id);
      }, 1000);
    }
  }
</script>
